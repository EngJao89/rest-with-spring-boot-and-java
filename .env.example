# Copie este arquivo para .env e ajuste os valores:
#   cp .env.example .env
#
# O arquivo .env não é versionado (está no .gitignore).
# Localmente, o Spring Boot carrega .env automaticamente (application.yml).
# Com Docker, o docker-compose também usa este arquivo.

# JWT (obrigatório)
JWT_SECRET_KEY=change-me-use-a-long-random-secret

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=db_port
MYSQL_DATABASE=rest_with_spring_boot
MYSQL_USER=app_user
MYSQL_PASSWORD=minha_senha

# Upload de arquivos
FILE_UPLOAD_DIR=uploads

# E-mail (opcional; usado em testes com application-test.yml)
EMAIL_USERNAME=
EMAIL_PASSWORD=